{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "manuscript-checker-cf",
	"main": "src/entry.py",
	"compatibility_date": "2026-07-08",
	"compatibility_flags": ["python_workers"],
	"observability": {
		"enabled": true
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "manuscripts-db",
			"database_id": "b1a0221c-0170-4b47-aa0f-6fe977b0d348"
		}
	],
	"triggers": {
		"crons": ["*/10 * * * *"]
	}
}
